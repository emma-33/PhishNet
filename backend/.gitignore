# Virtual environment
venv/
.venv/
env/
ENV/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Database files (sensitive user data)
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
phishnet.db
test.db

# Instance folder (may contain config with secrets)
instance/

# Environment variables (contains API keys, SMTP passwords)
.env
.env.local
.env.production

# SSL/TLS certificates
*.crt
*.key
*.pem
*.cert

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# Logs (may contain sensitive information)
*.log
logs/
gophish.log

# Flask session files
flask_session/

# Distribution / packaging
dist/
build/
*.egg-info/
